; Skynet configuration file for MMO Server
; This is a sample configuration for integrating skynet into the MMO framework

; Thread configuration
thread = 4

; Logger configuration
logger = nil
logservice = "logger"

; Module paths
cpath = "./cservice/?.so;./build/cservice/?.so"

; Lua library paths
lpath = "./lualib/?.lua;./lualib/?/init.lua;./third_party/skynet/lualib/?.lua;./third_party/skynet/lualib/?/init.lua"

; Lua service paths
luaservice = "./service/?.lua;./third_party/skynet/service/?.lua"

; Snax service paths
snax = "./service/?.lua;./third_party/skynet/service/?.lua"

; Bootstrap configuration
bootstrap = "snlua bootstrap"

; Harbor configuration (for multi-node cluster)
harbor = 0

; Node address (for cluster mode)
; address = "127.0.0.1:2526"

; Master node configuration (for cluster mode)
; master = "127.0.0.1:2013"

; Standalone mode
standalone = "0.0.0.0:2013"

; Profile enable
profile = 1

; Memory limit (in MB)
; memlimit = 256

; Start service
start = "main"

; Main service configuration
[main]
; Main service entry point
; This will be loaded when skynet starts

; Example services to load
; You can add your custom services here
; service1 = "examples/simpledb"
; service2 = "examples/watchdog"

; MMO specific configuration
[mmo]
; Enable MMO framework integration
enable_mmo = true

; Message forwarding to MMO services
forward_to_mmo = true

; Lua service directory for MMO
mmo_service_dir = "./lua/service"
